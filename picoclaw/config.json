{
  "version": 3,
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace",
      "restrict_to_workspace": true,
        "allow_read_outside_workspace": false,
        "provider": "",
        "model_name": "qwen3.5-397b-a17b",
        "max_tokens": 4096,
        "context_window": 32000,
        "max_tool_iterations": 50,
        "summarize_message_threshold": 20,
        "summarize_token_percent": 75,
        "steering_mode": "one-at-a-time",
        "subturn": {
          "max_depth": 0,
          "max_concurrent": 0,
          "default_timeout_minutes": 0,
          "default_token_budget": 0,
          "concurrency_timeout_sec": 0
        },
        "tool_feedback": {
          "enabled": false,
          "max_args_length": 300,
          "separate_messages": false
        },
        "split_on_marker": false
    }
  },
  "model_list": [
    {
      "model_name": "qwen3.5-397b-a17b",
      "provider": "openrouter",
      "model": "qwen/qwen3.5-397b-a17b",
      "api_base": "https://openrouter.ai/api/v1"
    }
  ],
  "channel_list": {
    "telegram": {
      "enabled": false,
      "type": "telegram",
      "allow_from": [
        "566572635"
      ],
      "reasoning_channel_id": "",
      "group_trigger": {},
      "typing": {
        "enabled": true
      },
      "placeholder": {
        "enabled": true,
        "text": [
          "Thinking... 💭"
        ]
      },
      "settings": {
        "base_url": "",
        "proxy": "",
        "streaming": {
          "enabled": true,
          "throttle_seconds": 3,
          "min_growth_chars": 200
        },
        "use_markdown_v2": false
      }
    }
  },
  "tools": {
    "allow_read_paths": null,
    "allow_write_paths": null,
    "web": {
      "enabled": true,
      "prefer_native": true,
      "format": "plaintext",
      "provider": "auto",
      "sogou": {
        "enabled": true,
        "max_results": 5
      },
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      },
      "fetch_limit_bytes": 5242880,
      "private_host_whitelist": []
    },
    "cron": {
      "enabled": true,
      "exec_timeout_minutes": 5
    },
    "mcp": {
      "enabled": false
    },
    "exec": {
      "enabled": true,
      "enable_deny_patterns": true,
      "custom_deny_patterns": null,
      "custom_allow_patterns": null
    },
    "skills": {
      "enabled": false
    },
    "append_file": { "enabled": true },
    "edit_file":   { "enabled": true },
    "list_dir":    { "enabled": true },
    "message":     { "enabled": true },
    "read_file":   { "enabled": true, "mode": "bytes" },
    "subagent":    { "enabled": true },
    "spawn":       { "enabled": true },
    "web_fetch":   { "enabled": true },
    "write_file":  { "enabled": true },

    "i2c":     { "enabled": false },
    "serial":  { "enabled": false },
    "spi":     { "enabled": false },
    "send_tts":{ "enabled": false }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "devices": { "enabled": false, "monitor_usb": false },
  "voice": { "model_name": "", "echo_transcription": false },
  "hooks": {
    "enabled": true,
    "defaults": {
      "observer_timeout_ms": 500,
      "interceptor_timeout_ms": 5000,
      "approval_timeout_ms": 60000
    }
  },
  "events": {
    "logging": {
      "enabled": true,
      "include": ["agent.*"],
      "exclude": [],
      "min_severity": "info",
      "include_payload": false
    }
  },
  "gateway": {
    "host": "localhost",
    "port": 18790,
    "hot_reload": false,
    "log_level": "warn"
  }
}
